{
  "--div-thickness": "1px",
  "--div-style": "solid",
  "--div-radius": "0px",
  "--div-spacing-micro": "var(--spacing-2)",
  "--div-spacing-tiny": "var(--spacing-4)",
  "--div-spacing-small": "var(--spacing-6)",
  "--div-spacing-base": "var(--spacing-8)",
  "--div-spacing-medium": "var(--spacing-10)",
  "--div-spacing-large": "var(--spacing-12)",
  "--div-spacing-big": "var(--spacing-14)",
  "--div-spacing-huge": "var(--spacing-16)",
  "--div-spacing-mega": "var(--spacing-20)",
  "--div-spacing-ultra": "var(--spacing-24)",
  "--div-indent-start": "0px",
  "--div-indent-end": "0px",
  "--div-min-length": "0px",
  "--div-max-length": "none",
  "--div-color": "var(--color-border)",
  "--div-color-strong": "var(--color-border-strong)",
  "--div-color-subtle": "var(--color-border-subtle)",
  "--div-opacity": "1",
  "--div-label-font-size": "var(--font-size-xs)",
  "--div-label-font-weight": "var(--font-weight-medium)",
  "--div-label-color": "var(--color-text-muted)",
  "--div-label-bg": "transparent",
  "--div-label-gap": "var(--spacing-8)",
  "--div-label-padding-x": "var(--spacing-8)",
  "--div-transition-property": "color, opacity",
  "--div-transition-duration": "var(--duration-fast)",
  "--div-transition-easing": "var(--easing-in-out)"
}